rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /sharp-limpieza/{moduleId}/{dateKey}/{fileName} {
      allow read: if request.auth != null && moduleId in ['cocina', 'servicio'];
      allow create, update: if moduleId in ['cocina', 'servicio']
        && request.auth != null
        && request.resource != null
        && request.resource.size <= 2 * 1024 * 1024
        && request.resource.contentType == 'image/jpeg';
      allow delete: if request.auth != null && moduleId in ['cocina', 'servicio'];
    }
  }
}
