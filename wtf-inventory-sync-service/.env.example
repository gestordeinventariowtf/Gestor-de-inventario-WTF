WTF_HOST_PORT=8787
WTF_WEB_APP_URL=https://gestor-de-inventario-wtf-prod-2026.web.app
WTF_FIREBASE_PROJECT_ID=gestor-de-inventario-wtf-29056
WTF_FIREBASE_COLLECTION=wtfSistema
WTF_FIREBASE_DOCUMENT_ID=estadoGeneral
WTF_AUTO_APPLY_ICG_CMS=true
WTF_API_KEY=cambie-esta-clave-local
WTF_BRANCH=principal
WTF_DEFAULT_WAREHOUSE=1
WTF_MODE=manual
WTF_POLL_SECONDS=30

# Carpeta base del servicio local.
WTF_DATA_DIR=./data

# Carpeta donde ICG FrontRest deja el CMS despues del cierre Z.
ICG_CMS_DIR=C:\ICG EXPORTACION

# Carpeta donde se colocan paquetes JSON exportados desde ICG Host Web.
ICG_EXPORT_DIR=./data/inbox

# Carpeta donde el servicio genera archivos para revisar/importar en ICG.
ICG_IMPORT_DIR=./data/outbox

# Carpetas de trazabilidad.
WTF_PROCESSED_DIR=./data/processed
WTF_QUARANTINE_DIR=./data/quarantine

# Fase futura: solo lectura SQL Server hasta validar esquema real de ICG.
ICG_SQL_ENABLED=false
ICG_SQL_CONNECTION_STRING=Server=localhost;Database=ICGFrontRest;Trusted_Connection=True;TrustServerCertificate=True
