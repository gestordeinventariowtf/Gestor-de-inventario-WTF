WTF_HOST_PORT=8787
WTF_WEB_APP_URL=https://gestor-de-inventario-wtf-prod-2026.web.app
WTF_API_KEY=change-me-before-production
WTF_BRANCH=principal
WTF_DEFAULT_WAREHOUSE=1
WTF_MODE=manual

# Carpeta donde ICG FrontRest o el operador dejara exportaciones para revisar.
ICG_EXPORT_DIR=./data/inbox

# Carpeta donde este servicio dejara archivos listos para importar en ICG.
ICG_IMPORT_DIR=./data/outbox

# Conexion SQL Server opcional. No se usa hasta aprobar auditoria tecnica.
ICG_SQL_ENABLED=false
ICG_SQL_SERVER=localhost
ICG_SQL_DATABASE=
ICG_SQL_USER=
ICG_SQL_PASSWORD=
